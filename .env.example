# Lexcom Sales Agent
# Copy to .env and fill in values

# === ConnectWise Manage ===
CW_SITE_URL=https://portal.lexcom.ca/v4_6_release/apis/3.0
CW_COMPANY_ID=Lexcom
CW_PUBLIC_KEY=
CW_PRIVATE_KEY=
CW_CLIENT_ID=

# === TD Synnex StreamOne Ion ===
# Credentials come from the TD Synnex API Center:
#   https://api.synnex.com/api-center/user/reseller/account?resourceKey=apiKeys
#
# This MCP specifically targets StreamOne Ion V3 (OAuth2 refresh-token flow).
# The API Center issues keys for multiple Synnex products — grab a StreamOne Ion
# refresh token, not a Reseller/EC API key (different auth model, not supported here).
#
# TDSYNNEX_HOSTNAME         = tenant-specific host (e.g. api.streamone.ion.td.com)
# TDSYNNEX_ACCOUNT_ID       = reseller account id
# TDSYNNEX_REFRESH_TOKEN    = single-use, 32-day lifetime — rotates on each API use
TDSYNNEX_HOSTNAME=
TDSYNNEX_ACCOUNT_ID=
TDSYNNEX_REFRESH_TOKEN=

# === Ollama (optional — future AI matching) ===
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct-v0.3-q4_K_M
